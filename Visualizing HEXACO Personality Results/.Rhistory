library(tidyverse)
library(ggradar)
install.packages("ggradar")
# 假设你的原始长数据 (Long format) 是这样的：
# domain_means <- tibble(
#   domain = c("Honesty-Humility", "Emotionality", "Extraversion", "Agreeableness", "Conscientiousness", "Openness"),
#   mean_score = c(4.5, 3.2, 5.1, 4.8, 5.5, 6.0)
# )
# 将长数据转换为宽数据 (Wide format)
radar_data_wide <- domain_means %>%
# 添加一个标识列，代表这是谁的数据
mutate(group = "My HEXACO Profile") %>%
# 将 domain 列的值变成新的列名，把 mean_score 填入对应位置
pivot_wider(names_from = domain, values_from = mean_score) %>%
# 确保 group 列在最前面（ggradar 的强制要求）
select(group, everything())
# 绘制图表
ggradar(
radar_data_wide,
# 1. 设置网格线范围 (Grid limits)
grid.min = 1,
grid.mid = 4,
grid.max = 7,
# 2. 设置网格线上显示的标签文本
values.radar = c("1", "4", "7"),
# 3. 视觉美化 (Aesthetics)
group.line.width = 1,
group.point.size = 3,
group.colours = "steelblue",       # 线的颜色
background.circle.colour = "white", # 背景色设置为干净的白色
gridline.mid.colour = "grey",      # 中间网格线的颜色
# 如果你只有自己一个人的数据，可以关掉图例 (Legend)
plot.legend = FALSE
)
