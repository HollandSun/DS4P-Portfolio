library(tidyverse)
library(IPV)
my_profile <- tibble(
domain = rep(c("H", "E", "X", "A", "C", "O"), each = 4),
facet = c(
"Sincerity", "Fairness", "Greed Avoidance", "Modesty",
"Fearfulness", "Anxiety", "Dependence", "Sentimentality",
"Social Self-Esteem", "Social Boldness", "Sociability", "Liveliness",
"Forgiveness", "Gentleness", "Flexibility", "Patience",
"Organization", "Diligence", "Perfectionism", "Prudence",
"Aesthetic Appreciation", "Inquisitiveness", "Creativity", "Unconventionality"
),
score = c(
3.78, 5.69, 5.32, 1.92,   # H (domain mean = 4.03)
5.32, 4.84, 5.61, 4.35,   # E (domain mean = 5.09)
5.27, 6.42, 5.23, 5.64,   # X (domain mean = 5.9)
5.59, 5.74, 5.62, 5.36,   # A (domain mean = 5.76)
6.08, 6.06, 5.33, 5.76,   # C (domain mean = 6.11)
5.02, 5.69, 5.25, 5.51    # O (domain mean = 5.49)
)
)
# Domain-level means
domain_means <- my_profile %>%
group_by(domain) %>%
summarise(mean_score = mean(score), .groups = "drop") %>%
mutate(domain_full = c("Agreeableness", "Conscientiousness", "Emotionality",
"Honesty-Humility", "Openness", "Extraversion"))
domain_means
library(tidyverse)
library(IPV)
my_profile <- tibble(
domain = rep(c("H", "E", "X", "A", "C", "O"), each = 4),
facet = c(
"Sincerity", "Fairness", "Greed Avoidance", "Modesty",
"Fearfulness", "Anxiety", "Dependence", "Sentimentality",
"Social Self-Esteem", "Social Boldness", "Sociability", "Liveliness",
"Forgiveness", "Gentleness", "Flexibility", "Patience",
"Organization", "Diligence", "Perfectionism", "Prudence",
"Aesthetic Appreciation", "Inquisitiveness", "Creativity", "Unconventionality"
),
score = c(
3.78, 5.69, 5.32, 1.92,   # H (domain mean = 4.03)
5.32, 4.84, 5.61, 4.35,   # E (domain mean = 5.09)
5.27, 6.42, 5.23, 5.64,   # X (domain mean = 5.9)
5.59, 5.74, 5.62, 5.36,   # A (domain mean = 5.76)
6.08, 6.06, 5.33, 5.76,   # C (domain mean = 6.11)
5.02, 5.69, 5.25, 5.51    # O (domain mean = 5.49)
)
)
# Domain-level means
domain_means <- my_profile %>%
group_by(domain) %>%
summarise(mean_score = mean(score), .groups = "drop") %>%
mutate(domain_full = c("Agreeableness", "Conscientiousness", "Emotionality",
"Honesty-Humility", "Openness", "Extraversion"))
domain_means
# Prepare data for radar chart
# coord_polar needs data in a specific format
radar_data <- domain_means %>%
# Close the polygon by repeating the first point
bind_rows(domain_means %>% slice(1))
ggplot(radar_data, aes(x = domain, y = mean_score, group = 1)) +
geom_polygon(fill = "steelblue", alpha = 0.2, color = "steelblue", linewidth = 1) +
geom_point(color = "steelblue", size = 3) +
coord_polar(start = 0) +
scale_y_continuous(limits = c(0, 5), breaks = 1:5) +
labs(title = "HEXACO Personality Profile (Radar Chart)",
subtitle = "Domain-level means on a 1-5 scale") +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, color = "gray40"),
axis.text.x = element_text(size = 10, face = "bold"),
axis.title = element_blank()
)
View(domain_means)
View(my_profile)
View(radar_data)
View(domain_means)
View(radar_data)
View(domain_means)
View(radar_data)
